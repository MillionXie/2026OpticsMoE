{
  "dataset": "bdd100k_timeofday3",
  "data_root": "../data/bdd100k_timeofday3",
  "download": true,
  "imagefolder_train": "train",
  "imagefolder_test": "test",
  "input_size": 224,
  "num_classes": 3,
  "class_names": [
    "daytime",
    "night",
    "dawn_dusk"
  ],
  "validation_fraction": 0.1,
  "epochs": 100,
  "batch_size": 32,
  "num_workers": 8,
  "optimizer": "adamw",
  "learning_rate": 0.001,
  "weight_decay": 0.0005,
  "scheduler": "cosine",
  "seed": 42,
  "device": "cuda",
  "progress": true,
  "log_interval_batches": 50,
  "save_interval_epochs": 10,
  "save_predictions_interval_epochs": 1,
  "train_limit": null,
  "test_limit": null,
  "train_limit_per_class": null,
  "test_limit_per_class": null,
  "train_samples_per_class_per_epoch": null,
  "model_type": "optical5_enhanced",
  "output_dir": "../runs/bdd100k_timeofday3_optical5_enhanced_balanced",
  "optical_layers": 5,
  "optical_field_size": 256,
  "optical_padding_size": 400,
  "wavelength_nm": 532.0,
  "pixel_pitch_um": 17.0,
  "mask_distance_cm": 5.0,
  "phase_init": "uniform",
  "amplitude_mask_enabled": true,
  "intensity_forward": true,
  "readout_channels": [
    16,
    32
  ],
  "readout_pool_size": 8,
  "readout_hidden_dim": 256,
  "readout_dropout": 0.2,
  "detector_region_size": 48,
  "detector_region_temperature": 1.0,
  "detector_region_loss_weight": 1.0,
  "detector_concentration_loss_weight": 0.1,
  "regularization": {
    "phase_dropout": {
      "enabled": true,
      "p": 0.05,
      "mode": "block_phase_bypass",
      "block_size": 8,
      "batch_shared": true,
      "start_epoch": 10
    }
  }
}
