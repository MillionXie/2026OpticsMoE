{
  "config_version": 2,
  "experiment": {
    "name": "qwen3_vl_2b_flickr30k_itm_vision_language_homogeneous_moe9",
    "output_dir": "../runs/qwen3_vl_2b_flickr30k_itm_vision_language_homogeneous_moe9",
    "seed": 42
  },
  "dataset": {
    "name": "flickr30k_image_text_matching",
    "data_root": "../../../data/flickr30k",
    "repo_id": "nlphuji/flickr30k",
    "revision": null,
    "hf_endpoint": "https://hf-mirror.com",
    "download": true,
    "validate_standard_counts": true,
    "captions_per_image": 1,
    "negatives_per_positive": 1,
    "negative_sampling_algorithm": "stable_caption_sattolo_derangement_v1",
    "train_image_limit": null,
    "test_image_limit": null,
    "train_samples_per_epoch": null,
    "train_samples_per_class_per_epoch": 2000,
    "resolved_fingerprints": null,
    "pair_manifest_digests": null
  },
  "qwen": {
    "model_id": "Qwen/Qwen3-VL-2B-Instruct",
    "cache_dir": null,
    "local_files_only": false,
    "prompt_template": "Determine whether the caption accurately describes the image.\nCaption: {caption}\nMatch score:",
    "processor": {
      "min_pixels": 20480,
      "max_pixels": 20480
    },
    "runtime": {
      "dtype": "bfloat16",
      "attn_implementation": "sdpa",
      "device": "cuda"
    },
    "architecture": {
      "vision_depth": null,
      "vision_hidden_size": null,
      "text_depth": null,
      "text_hidden_size": null,
      "deepstack_visual_indexes": null
    }
  },
  "student": {
    "language_stack_mode": "optical_moe",
    "initialize_head_from_teacher": false,
    "transformer_block_alignment": {
      "native_pre_attention_enabled": true,
      "native_pre_attention_trainable": true,
      "residual_enabled": true,
      "vision_attention_source_layer": 0,
      "language_attention_source_layer": 0
    }
  },
  "batching": {
    "feature_batch_size": 32,
    "student_batch_size": 8,
    "inference_batch_size": 8,
    "head_batch_size": 512,
    "num_workers": 8
  },
  "teacher_cache": {
    "dtype": "float16",
    "shard_size": 128,
    "lru_shards": 8,
    "log_interval_batches": 100
  },
  "vision_adapter": {
    "optical_channels": 120,
    "max_visual_tokens": 120,
    "tap_stages": [1, 3, 4]
  },
  "language_adapter": {
    "max_language_tokens": 120
  },
  "moe": {
    "geometry": {
      "canvas_size": 480,
      "active_size": 450,
      "num_experts": 9,
      "expert_size": 120,
      "expert_pitch": 150,
      "layers_per_expert": 5
    },
    "router": {
      "top_k": 3,
      "pool_size": 10,
      "temperature": 1.0,
      "learning_rate": 0.001,
      "input_layernorm_enabled": true,
      "input_layernorm_eps": 0.00001
    },
    "optics": {
      "wavelength_nm": 532.0,
      "pixel_pitch_um": 16.0,
      "prompt_focal_length_m": 0.0722,
      "distances_m": {
        "prompt_to_expert": 0.1444,
        "inter_layer": 0.2,
        "last_expert_to_global": 0.2,
        "global_to_detector": 0.2
      },
      "phase": {
        "parameterization": "sigmoid",
        "init": "zeros",
        "init_std": 0.02
      },
      "k_space": {
        "enabled": false,
        "theta_max_deg": 1.0
      }
    },
    "optoelectronic_interlayers": {
      "enabled": true,
      "per_expert_enabled": true,
      "elementwise_affine": false,
      "hard_route_mask": true,
      "reapply_routing_weights": true,
      "layernorm_eps": 0.00001,
      "nonlinearity": "relu"
    },
    "final_detector_readout": {
      "pool_kernel": 4,
      "layernorm_eps": 0.00001,
      "layernorm_affine": false,
      "layernorm_scope": "per_token",
      "nonlinearity": "relu"
    }
  },
  "classification_head": {
    "type": "normalized_binary_classification",
    "threshold": 0.5
  },
  "loss": {
    "vision_hidden_weight": 1.0,
    "answer_hidden_weight": 1.0,
    "logit_distill_weight": 0.5,
    "classification_weight": 1.0,
    "smooth_l1_beta": 0.1,
    "router_balance_weight": 0.03,
    "router_importance_weight": 0.0
  },
  "optimizer": {
    "type": "adamw",
    "learning_rate": 0.008,
    "student_head_learning_rate": 0.001,
    "weight_decay": 0.0,
    "scheduler": "cosine"
  },
  "training": {
    "epochs": 100,
    "progress": true,
    "logging": {
      "interval_batches": 4000
    },
    "checkpoint_interval_epochs": 10,
    "student_selection_split": "test",
    "student_selection_metric": "auroc"
  },
  "regularization": {
    "phase_dropout": {
      "enabled": true,
      "mode": "block_phase_bypass",
      "p": 0.02,
      "block_size": 4,
      "batch_shared": true,
      "start_epoch": 5
    }
  },
  "visualization": {
    "enabled": true,
    "interval_epochs": 10,
    "save_phase_masks": true,
    "save_training_curves": true,
    "save_confusion_matrix": true,
    "save_predictions": true
  }
}
